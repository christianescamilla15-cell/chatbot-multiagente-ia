{
  "name": "01-chatbot-multiagente",
  "version": "1.0.0",
  "description": "Chatbot Multiagente de Atención al Cliente — 5 agentes IA especializados",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --port 3001",
